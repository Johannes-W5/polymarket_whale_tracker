# Copy to .env and load in your shell, or export manually.
# Do not commit real secrets.

# --- Database (use either DATABASE_URL or PG_* ) ---
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
PG_DB=whaletracker
PG_USER=whaletracker
PG_PASSWORD=change-me
PG_HOST=localhost
PG_PORT=5432

# --- Polymarket API proxy (local or deployed) ---
POLYMARKET_API_BASE=http://127.0.0.1:8000

# --- News dataset files (optional overrides) ---
# NEWS_EVENTS_PATH=news_scraper/data/news_events.jsonl
# NEWS_EVENTS_METADATA_PATH=news_scraper/data/news_events.metadata.json

# --- LLM (Ollama Cloud or compatible API) ---
# OLLAMA_API_KEY=
# OLLAMA_HOST=https://ollama.com
# OLLAMA_MODEL=qwen3.5:cloud
# CROSS_ASSET_OLLAMA_MODEL=qwen3.5:cloud

# --- X/Twitter (only if enabled in news_scraper/config.py) ---
# X_BEARER_TOKEN=

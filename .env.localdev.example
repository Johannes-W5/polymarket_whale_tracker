# Local development profile (copy to .env.local and edit).
# Load with: source scripts/use_env.sh local
#
# Prefer Neon (or any Postgres URL). When DATABASE_URL is set, PG_* is ignored.

# Quote the whole URL: & in ?sslmode=require&channel_binding=... breaks `source` otherwise.
DATABASE_URL='postgresql://USER:PASSWORD@YOUR-NEON-HOST/neondb?sslmode=require&channel_binding=require'

# --- Local proxy ---
POLYMARKET_API_BASE=http://127.0.0.1:8000

# --- Optional: local Postgres (only if DATABASE_URL is unset) ---
# PG_DB=whaletracker
# PG_USER=whaletracker
# PG_PASSWORD=change-me
# PG_HOST=localhost
# PG_PORT=5432

# --- Optional ---
# OLLAMA_API_KEY=
# OLLAMA_HOST=https://ollama.com
# OLLAMA_MODEL=qwen3.5:cloud
# CROSS_ASSET_OLLAMA_MODEL=qwen3.5:cloud
